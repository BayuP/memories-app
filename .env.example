# Postgres (used by docker-compose)
POSTGRES_USER=memories
POSTGRES_PASSWORD=memories
POSTGRES_DB=memories_app

# Backend
ENV=development
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# S3 / Cloudflare R2
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic API
ANTHROPIC_API_KEY=
